{
  "$schema": "https://renovatebot.com",
  "extends": ["config:best-practices"],
  "pruneStaleBranches": true,
  "rebaseWhen": "behind-base-branch",
  "recreateWhen": "always",
  "prCreation": "immediate",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "dependencyDashboard": false,
  "packageRules": [
    {
      "description": "Allow Go modules updates entirely",
      "matchManagers": ["gomod"],
      "enabled": true
    },
    {
      "description": "Allow major updates for Dockerfiles",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["major"],
      "enabled": true
    },
    {
      "description": "Enable silent auto-merge for GitHub Actions patch and minor updates via PR",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Allow updates inside the legacy directory",
      "matchFileNames": ["**/legacy-code/**"],
      "enabled": true
    },
    {
      "description": "Allow automatic PRs for npm major packages (No dashboard approval needed)",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["major"],
      "enabled": true
    }
  ]
}